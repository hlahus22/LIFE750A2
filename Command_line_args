## Environment creation arguments
mamba create -c conda-forge -c bioconda -n life750_qc fastqc multiqc
mamba create -c conda-forge -c bioconda -n life750_genomics bwa samtools bcftools bedtools freebayes

# Runs quality control to see the quality of the raw sequences 
fastqc *.fastq *.fa

# Index reference genome
bwa index GeneX_reference.fa

#Run mapping and sorting for wildtypes
## -t 8 was used to utilise my laptops stronger CPU
bwa mem -t 8 -R '@RG\tID:Normal\tSM:Normal\tPL:ILLUMINA\tLB:WGS' GeneX_reference.fa normal_GeneX_R1.fastq normal_GeneX_R2.fastq w| samtools view -b -@ 8 
| samtools sort -@ 8 -o normal_sorted.bam -

# Run mapping and sorting for mutants
bwa mem -t 8 -R '@RG\tID:Mutant\tSM:Mutant\tPL:ILLUMINA\tLB:WGS' GeneX_reference.fa mutant_GeneX_R1.fastq mutant_GeneX_R2.fastq | samtools view -b -@ 8 | samtools sort -@ 8 -o mutant_sorted.bam -

# Varient calling
freebayes --ploidy 1 --min-mapping-quality 30 --min-base-quality 25 --fasta-reference GeneX_reference.fa normal_sorted.bam mutant_sorted.bam > GeneX_raw.vcf

# Filter to show only call varients
grep -v "^#" GeneX_final_filtered.vcf > varients.txt

# Filters just the genes from the provided gff3 file
awk '$3 == "gene"' genes.gff3 > isolated_genes.gff3

# Intersected the bed file to the gff to find the binding sites
bedtools intersect -a isolated_genes.gff3 -b gene_x_binding_sites.bed > geneX_targets.gff3
